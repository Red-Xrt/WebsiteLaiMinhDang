@model IEnumerable<LaiMinhDang.SachOnline.Models.SACH>
@{
    ViewBag.Title = "SachTheoNhaXuatBan";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

@section slider{
    @Html.Action("SliderPartial", "SachOnline")
}
<h2 class="text-center">
    SÁCH THEO NHÀ SẢN XUẤT:
    @(ViewBag.TenNXB ?? "Không xác định")
</h2>

<hr />

<div class="row text-center">
    @foreach (var sach in Model)
    {
        <div class="col-sm-4 col-md-4 col-lg-4 col-xs-6">
            <div class="thumbnail">
                <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })">
                    <img src="~/Images/@(sach.TenSach).jpg"
                         class="img-responsive img-rounded imgbook"
                         style="width:100%; height:400px; object-fit:cover;" />
                </a>

                <div class="caption">
                    <h4 style="min-height:70px;">
                        <a href="@Url.Action("ChiTietSach","SachOnline",
                            new { id = sach.MaSach })">
                            @sach.TenSach
                        </a>
                    </h4>
                    <p>
                        <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })" class="btn btn-primary">
                            <span class="glyphicon glyphicon-shopping-cart"></span>
                            Add to Cart
                        </a>
                    </p>
                </div>
            </div>
        </div>
    }
    <div class="clearfix"></div>
    <nav class="text-center">
        <ul class="pagination">
            <li> <a href="#" aria-label="Previous"> <span aria-hidden="true">&laquo;</span> </a> </li>
            <li class="active"><a href="#">1</a></li>
            <li><a href="#">2</a></li>
            <li><a href="#">3</a></li>
            <li><a href="#">4</a></li>
            <li class="disabled"><a href="#">5</a></li>
            <li> <a href="#" aria-label="Next"> <span aria-hidden="true">&raquo;</span> </a> </li>
        </ul>
    </nav>
</div>


