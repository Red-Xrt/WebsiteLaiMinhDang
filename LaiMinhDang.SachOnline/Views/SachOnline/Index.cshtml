@model IEnumerable<HoangDinhTuanAnh.SachOnline.Models.SACH>

@{
    ViewBag.Title = "Trang Chủ";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

@section slider{
    @Html.Action("SliderPartial", "SachOnline")
}

<style>
    .imgbook {
        transition: all ease 0.5s;
        width: 100%;
        height: 300px;
        object-fit: cover;
    }

        .imgbook:hover {
            transform: scale(1.1);
        }
</style>

<h2 class="text-center">SÁCH MỚI</h2>
<hr />

<div class="row text-center">

    @foreach (var sach in Model)
    {
        <div class="col-sm-4 col-md-4 col-lg-4 col-xs-6">
            <div class="thumbnail">

                <img src="~/Images/@sach.AnhBia"
                     class="img-responsive img-rounded imgbook" />

                <div class="caption">

                    <h4 style="min-height:60px;">
                        <a href="@Url.Action("ChiTietSach","SachOnline", new { id = sach.MaSach })">
                            @sach.TenSach
                        </a>
                    </h4>

                    <p>Mô tả tóm tắt sản phẩm</p>

                    <p>
                        <a href="@Url.Action("ChiTietSach","SachOnline", new { id = sach.MaSach })"
                           class="btn btn-primary">

                            <span class="glyphicon glyphicon-shopping-cart"></span>
                            Add to Cart
                        </a>
                    </p>

                </div>

            </div>
        </div>
    }

</div>

<!-- PHÂN TRANG -->
<nav class="text-center">
    <ul class="pagination">
        <li>
            <a href="#"><span>&laquo;</span></a>
        </li>

        <li class="active"><a href="#">1</a></li>
        <li><a href="#">2</a></li>
        <li><a href="#">3</a></li>
        <li><a href="#">4</a></li>

        <li>
            <a href="#"><span>&raquo;</span></a>
        </li>
    </ul>
</nav>

@section sachbannhieu{
    @Html.Action("SachBanNhieuPartial", "SachOnline")
}