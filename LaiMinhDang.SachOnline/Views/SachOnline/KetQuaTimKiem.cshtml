@using LaiMinhDang.SachOnline.Models
@using PagedList.Mvc;
@model PagedList.PagedList<SACH>

@{
    ViewBag.Title = "Kết quả tìm kiếm";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<h2 class="text-center" style="margin-top:20px; font-weight:bold; color:#d9534f">
    KẾT QUẢ TÌM KIẾM CHO: "@ViewBag.TuKhoa"
</h2>
<hr />

<div class="row">
    @if (Model.Count == 0)
    {
        <div class="col-md-12 text-center">
            <h4 style="color:red;">Không tìm thấy kết quả nào phù hợp.</h4>
        </div>
    }
    else
    {
        foreach (var sach in Model)
        {
            <div class="col-sm-4 col-md-4">
                <div class="thumbnail" style="border: 1px solid #ddd; border-radius: 5px; box-shadow: 2px 2px 5px rgba(0,0,0,0.1); padding: 10px;">
                    <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })">
                        <img src="~/Images/@sach.AnhBia" alt="@sach.TenSach" class="img-responsive" style="height:250px; object-fit:cover; width:100%; border-radius: 3px;" />
                    </a>
                    <div class="caption text-center">
                        <h4 style="font-size: 16px; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 10px; margin-bottom: 5px;">
                            <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })" style="color: #337ab7; text-decoration: none;">@sach.TenSach</a>
                        </h4>
                        <p style="color: #d9534f; font-weight: bold; font-size: 16px; margin-bottom: 15px;">
                            @String.Format("{0:0,0}", sach.GiaBan) VNĐ
                        </p>
                        <p>
                            <a href="@Url.Action("ThemGioHang", "GioHang", new { ms = sach.MaSach, url = Request.Url.ToString() })" class="btn btn-success" role="button" style="width: 100%;">
                                <span class="glyphicon glyphicon-shopping-cart"></span> Đặt mua
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (Model.PageCount > 1)
{
    <div class="text-center">
        @Html.PagedListPager(Model, page => Url.Action("KetQuaTimKiem", new { page = page, data = ViewBag.TuKhoa }))
    </div>
}
