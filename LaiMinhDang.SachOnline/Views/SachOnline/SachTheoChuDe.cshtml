@model IEnumerable<HoangDinhTuanAnh.SachOnline.Models.SACH>

@{
    ViewBag.Title = "Sách theo chủ đề";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<h2 class="text-center">
    SÁCH THEO CHỦ ĐỀ: @ViewBag.TenChuDe
</h2>

<hr />

<div class="row text-center">
    @foreach (var item in Model)
    {
        <div class="col-sm-4 col-md-4 col-lg-4 col-xs-6">
            <div class="thumbnail">
                <img src="~/Images/@item.AnhBia"
                     class="img-responsive img-rounded imgbook" />

                <div class="caption">
                    <h4>@item.TenSach</h4>

                    <p style="color:red;font-weight:bold">
                        @String.Format("{0:0,0}", item.GiaBan) VNĐ
                    </p>

                    <p>
                        <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = item.MaSach })"
                           class="btn btn-primary">
                            Chi tiết
                        </a>
                    </p>
                </div>
            </div>
        </div>
    }
</div>