@model IEnumerable<LaiMinhDang.SachOnline.Models.GioHang>
@{
    ViewBag.Title = "Giỏ Hàng";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<h2 style="text-align:center;">THÔNG TIN GIỎ HÀNG</h2>

@if (Model == null || !Model.Any())
{
    <div style="text-align:center; font-size:18px; color:red; margin-top:20px;">
        <p>Giỏ hàng của bạn đang trống.</p>
        <br />
        <a href="@Url.Action("Index", "SachOnline")" class="btn btn-primary">Quay lại trang chủ</a>
    </div>
}
else
{
    <table border="1" style="width:100%">
        <tr style="background-color:#9ca1a4; font-size:15px; font-weight:bold; text-align:center;">
            <td>Mã Sách</td>
            <td>Tên Sách</td>
            <td>Ảnh Bìa</td>
            <td>Số Lượng</td>
            <td>Đơn Giá</td>
            <td>Thành Tiền</td>
            <td></td>
            <td></td>
            <td></td>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td align="center">@item.iMaSach</td>
                <td>@item.sTenSach</td>
                <td align="center"><img src="~/Images/@item.sAnhBia" style="width:100px;"></td>

                @using (Html.BeginForm("CapNhatGioHang", "GioHang", new { iMaSach = item.iMaSach }))
                {
                    <td align="center">
                        <input type="number" min="1" name="txtSoLuong" value="@item.iSoLuong" style="background-color:#f4ff94" />
                    </td>
                    <td align="center">@string.Format("{0:#,##0,0}", @item.dDonGia)</td>
                    <td align="center">@string.Format("{0:#,##0,0}", @item.dThanhTien)</td>
                    <td align="center"><a href="@Url.Action("ChiTietSach", "SachOnline", new { id = item.iMaSach })">Chi tiết</a></td>
                    <td align="center">@Html.ActionLink("Xóa", "XoaGioHang", new { @iMaSach = item.iMaSach })</td>
                    <td align="center">
                        <input type="submit" value="Cập nhật" />
                    </td>
                }
            </tr>
        }
        <tr>
            <td colspan="4" style="text-align:right; color:red; font-weight:bold; padding-right:5px;">
                Tổng số lượng: @string.Format("{0:#,##0}", @ViewBag.TongSoLuong)
            </td>
            <td colspan="5" style="text-align:center; color:red; font-weight:bold;">
                Tổng tiền: @string.Format("{0:#,##0,0}", @ViewBag.TongTien) VNĐ
            </td>
        </tr>
        <tr style="font-weight:bold; color:blue; text-align:right;">
            <td colspan="9">
                @Html.ActionLink("Xóa giỏ hàng", "XoaTatCaGioHang")
            </td>
        </tr>
        <tr style="font-weight:bold; color:blue; text-align:right;">
            <td colspan="9">
                @Html.ActionLink("ĐẶT HÀNG", "DatHang", "GioHang")
            </td>
        </tr>
    </table>
}
