@model IEnumerable<LaiMinhDang.SachOnline.Models.GioHang>
@{
    ViewBag.Title = "Giỏ Hàng";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div style="text-align:center; margin-bottom: 30px;">
    <h2 style="font-weight: bold; color: #2c3e50;">
        <i class="glyphicon glyphicon-shopping-cart"></i> THÔNG TIN GIỎ HÀNG
    </h2>
    <p class="text-muted">Kiểm tra lại sách trong giỏ trước khi thanh toán</p>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center" style="font-size:16px; margin-top:20px; padding: 30px; border-radius: 8px;">
        <i class="glyphicon glyphicon-info-sign" style="font-size: 40px; margin-bottom: 15px; color: #f39c12; display: block;"></i>
        <p style="margin-bottom: 20px;">Giỏ hàng của bạn hiện đang trống. Hãy quay lại trang chủ để chọn sách nhé!</p>
        <a href="@Url.Action("Index", "SachOnline")" class="btn btn-primary btn-lg">
            <i class="glyphicon glyphicon-home"></i> Quay lại mua sắm
        </a>
    </div>
}
else
{
    <div class="table-responsive" style="border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <table class="table table-hover" style="margin-bottom: 0; background: white;">
            <thead style="background-color: #34495e; color: white;">
                <tr>
                    <th class="text-center" style="border-bottom: none; padding: 15px;">Mã Sách</th>
                    <th class="text-center" style="border-bottom: none; padding: 15px;">Tên Sách</th>
                    <th class="text-center" style="border-bottom: none; padding: 15px;">Ảnh Bìa</th>
                    <th class="text-center" style="border-bottom: none; padding: 15px;">Số Lượng</th>
                    <th class="text-center" style="border-bottom: none; padding: 15px;">Đơn Giá</th>
                    <th class="text-center" style="border-bottom: none; padding: 15px;">Thành Tiền</th>
                    <th class="text-center" style="border-bottom: none; padding: 15px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center" style="vertical-align: middle;">@item.iMaSach</td>
                    <td style="vertical-align: middle; font-weight: bold;">@item.sTenSach</td>
                    <td class="text-center" style="vertical-align: middle;">
                        <img src="~/Images/@item.sAnhBia" style="width: 80px; border-radius: 5px; box-shadow: 1px 1px 3px rgba(0,0,0,0.2);">
                    </td>

                    @using (Html.BeginForm("CapNhatGioHang", "GioHang", new { iMaSach = item.iMaSach }))
                    {
                        <td class="text-center" style="vertical-align: middle;">
                            <input type="number" min="1" name="txtSoLuong" value="@item.iSoLuong" class="form-control" style="width: 70px; display: inline-block; text-align: center;" />
                        </td>
                        <td class="text-center" style="vertical-align: middle; color: #d9534f; font-weight: bold;">
                            @string.Format("{0:#,##0,0}", @item.dDonGia)
                        </td>
                        <td class="text-center" style="vertical-align: middle; color: #d9534f; font-weight: bold;">
                            @string.Format("{0:#,##0,0}", @item.dThanhTien)
                        </td>
                        <td class="text-center" style="vertical-align: middle;">
                            <button type="submit" class="btn btn-info btn-sm" title="Cập nhật">
                                <i class="glyphicon glyphicon-refresh"></i> Cập nhật
                            </button>
                            <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = item.iMaSach })" class="btn btn-primary btn-sm" title="Chi tiết">
                                <i class="glyphicon glyphicon-eye-open"></i> Chi tiết
                            </a>
                            <a href="@Url.Action("XoaGioHang", "GioHang", new { iMaSach = item.iMaSach })" class="btn btn-danger btn-sm" title="Xóa">
                                <i class="glyphicon glyphicon-trash"></i> Xóa
                            </a>
                        </td>
                    }
                </tr>
            }
            </tbody>
            <tfoot>
                <tr style="background-color: #f9f9f9;">
                    <td colspan="4" class="text-right" style="font-size: 16px; font-weight: bold; color: #333; vertical-align: middle;">
                        Tổng số lượng: <span style="color: #d9534f;">@string.Format("{0:#,##0}", @ViewBag.TongSoLuong)</span>
                    </td>
                    <td colspan="3" class="text-center" style="font-size: 18px; font-weight: bold; color: #d9534f; vertical-align: middle;">
                        Tổng tiền: @string.Format("{0:#,##0,0}", @ViewBag.TongTien) VNĐ
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="row" style="margin-top: 20px;">
        <div class="col-md-6">
            <a href="@Url.Action("Index", "SachOnline")" class="btn btn-default">
                <i class="glyphicon glyphicon-arrow-left"></i> Tiếp tục mua hàng
            </a>
            <a href="@Url.Action("XoaTatCaGioHang", "GioHang")" class="btn btn-warning">
                <i class="glyphicon glyphicon-remove"></i> Xóa toàn bộ giỏ hàng
            </a>
        </div>
        <div class="col-md-6 text-right">
            <a href="@Url.Action("DatHang", "GioHang")" class="btn btn-success btn-lg">
                <i class="glyphicon glyphicon-ok"></i> TIẾN HÀNH ĐẶT HÀNG
            </a>
        </div>
    </div>
}
