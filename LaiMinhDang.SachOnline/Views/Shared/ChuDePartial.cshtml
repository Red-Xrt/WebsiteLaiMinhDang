@model IEnumerable<LaiMinhDang.SachOnline.Models.CHUDE>

<div class="list-group">
    <a href="#" class="list-group-item active text-center" style="font-weight:bold; background-color: #337ab7; border-color: #337ab7;">
        SÁCH THEO CHỦ ĐỀ
    </a>

    @foreach (var item in Model)
    {
        <a href="@Url.Action("SachTheoChuDe", "SachOnline", new { id = item.MaCD })" class="list-group-item">
            @item.TenChuDe
        </a>
    }
</div>