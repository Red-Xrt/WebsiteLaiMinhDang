<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>

    <link rel="stylesheet"
          href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>

    <style>
        body {
            background-color: #f5f5f5;
        }

        .main-content {
            background: white;
            padding: 15px;
        }

        .panel-heading {
            font-weight: bold;
        }
    </style>
</head>
<body>


    @Html.Action("NavPartial", "SachOnline")

    @RenderSection("slider", required: false)



    <div class="container main-content">
        <div class="row">


            <div class="col-md-3">
                @Html.Action("ChuDePartial", "SachOnline")
                <br />
                @Html.Action("NhaXuatBanPartial", "SachOnline")
            </div>


            <div class="col-md-9">
                @RenderBody()
            </div>

        </div>
    </div>


    <div class="container">
        @RenderSection("sachbannhieu", required: false)
    </div>

    @Html.ActionLink("Đăng ký", "DangKy", "HoangDinhTuanAnh_User")
    @Html.ActionLink("Đăng nhập", "DangNhap", "HoangDinhTuanAnh_User")

</body>
</html>
