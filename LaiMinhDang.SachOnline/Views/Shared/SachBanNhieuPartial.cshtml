@model IEnumerable<LaiMinhDang.SachOnline.Models.SACH>
<div class="container">
    <h2 class="text-center">SÁCH BÁN NHIỀU</h2>
    <hr />

    <div class="row">
        @foreach (var sach in Model)
        {
            <div class="col-md-4 col-sm-6">
                <div class="media">
                    <div class="media-left">
                        <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })">
                            <img src="~/Images/@(sach.TenSach).jpg"
                                 class="media-object"
                                 style="width:120px" />
                        </a>
                    </div>
                    <div class="media-body">
                        <h4 class="media-heading">
                            <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })">
                                @sach.TenSach
                            </a>
                        </h4>
                        <p>@sach.MoTa</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

