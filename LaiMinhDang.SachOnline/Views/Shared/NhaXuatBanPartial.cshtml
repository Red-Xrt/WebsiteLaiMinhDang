@model IEnumerable<HoangDinhTuanAnh.SachOnline.Models.NHAXUATBAN>

<ul class="list-group">
    <li class="list-group-item active text-center" style="font-weight:bold">
        SÁCH THEO NHÀ XUẤT BẢN
    </li>

    @foreach (var item in Model)
    {
        <li class="list-group-item">
            <a href="@Url.Action("SachTheoNhaXuatBan", "SachOnline", new { id = item.MaNXB })">
                @item.TenNXB
            </a>
        </li>
    }
</ul>