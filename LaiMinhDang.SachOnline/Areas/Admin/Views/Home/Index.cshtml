@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Title = "Admin Dashboard";
}

<h2 style="text-align:center; font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin-bottom: 30px;">
    TRANG CHỦ QUẢN TRỊ
</h2>

<div class="row">
    <!-- TỔNG SỐ ĐƠN HÀNG -->
    <div class="col-md-6">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <div class="row">
                    <div class="col-xs-3">
                        <i class="glyphicon glyphicon-shopping-cart" style="font-size: 50px;"></i>
                    </div>
                    <div class="col-xs-9 text-right">
                        <div style="font-size: 30px; font-weight: bold;">@ViewBag.SoLuongDonHang</div>
                        <div>Tổng Số Đơn Hàng</div>
                    </div>
                </div>
            </div>
            <a href="@Url.Action("Index", "DonHang", new { area = "Admin" })">
                <div class="panel-footer">
                    <span class="pull-left">Xem chi tiết</span>
                    <span class="pull-right"><i class="glyphicon glyphicon-circle-arrow-right"></i></span>
                    <div class="clearfix"></div>
                </div>
            </a>
        </div>
    </div>

    <!-- TỔNG DOANH THU -->
    <div class="col-md-6">
        <div class="panel panel-success">
            <div class="panel-heading">
                <div class="row">
                    <div class="col-xs-3">
                        <i class="glyphicon glyphicon-usd" style="font-size: 50px;"></i>
                    </div>
                    <div class="col-xs-9 text-right">
                        <div style="font-size: 30px; font-weight: bold;">@String.Format("{0:0,0}", ViewBag.TongDoanhThu) VNĐ</div>
                        <div>Tổng Doanh Thu</div>
                    </div>
                </div>
            </div>
            <a href="@Url.Action("Index", "DonHang", new { area = "Admin" })">
                <div class="panel-footer">
                    <span class="pull-left">Xem chi tiết</span>
                    <span class="pull-right"><i class="glyphicon glyphicon-circle-arrow-right"></i></span>
                    <div class="clearfix"></div>
                </div>
            </a>
        </div>
    </div>
</div>

<hr />
<h3 style="margin-bottom: 20px;">LỐI TẮT QUẢN LÝ</h3>
<div class="row">
    <div class="col-md-3">
        <a href="@Url.Action("Index", "Sach", new { area = "Admin" })" class="btn btn-primary btn-lg btn-block" style="padding: 20px;">
            <i class="glyphicon glyphicon-book" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Quản lý Sách
        </a>
    </div>
    <div class="col-md-3">
        <a href="@Url.Action("Index", "ChuDe", new { area = "Admin" })" class="btn btn-info btn-lg btn-block" style="padding: 20px;">
            <i class="glyphicon glyphicon-tags" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Quản lý Chủ đề
        </a>
    </div>
    <div class="col-md-3">
        <a href="@Url.Action("Index", "NhaXuatBan", new { area = "Admin" })" class="btn btn-warning btn-lg btn-block" style="padding: 20px;">
            <i class="glyphicon glyphicon-home" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Quản lý NXB
        </a>
    </div>
    <div class="col-md-3">
        <a href="@Url.Action("Index", "KhachHang", new { area = "Admin" })" class="btn btn-danger btn-lg btn-block" style="padding: 20px;">
            <i class="glyphicon glyphicon-user" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Quản lý Khách hàng
        </a>
    </div>
</div>
