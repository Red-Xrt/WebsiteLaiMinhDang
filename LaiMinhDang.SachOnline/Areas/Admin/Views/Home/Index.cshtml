@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Title = "Admin Dashboard";
}

<div style="text-align:center; margin-bottom: 40px;">
    <h2 style="font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: bold; color: #2c3e50;">
        <i class="glyphicon glyphicon-dashboard"></i> TRANG CHỦ QUẢN TRỊ
    </h2>
    <p class="text-muted">Tổng quan tình hình hoạt động của hệ thống SachOnline</p>
</div>

<div class="row">
    <!-- TỔNG SỐ ĐƠN HÀNG -->
    <div class="col-md-6">
        <div class="panel panel-info" style="box-shadow: 0 4px 8px rgba(0,0,0,0.1); border: none;">
            <div class="panel-heading" style="background-color: #3498db; color: white;">
                <div class="row">
                    <div class="col-xs-3">
                        <i class="glyphicon glyphicon-shopping-cart" style="font-size: 60px;"></i>
                    </div>
                    <div class="col-xs-9 text-right">
                        <div style="font-size: 36px; font-weight: bold;">@ViewBag.SoLuongDonHang</div>
                        <div style="font-size: 16px;">Tổng Số Đơn Hàng</div>
                    </div>
                </div>
            </div>
            <a href="@Url.Action("Index", "DonHang", new { area = "Admin" })">
                <div class="panel-footer" style="color: #3498db; font-weight: bold;">
                    <span class="pull-left">Xem chi tiết đơn hàng</span>
                    <span class="pull-right"><i class="glyphicon glyphicon-circle-arrow-right"></i></span>
                    <div class="clearfix"></div>
                </div>
            </a>
        </div>
    </div>

    <!-- TỔNG DOANH THU -->
    <div class="col-md-6">
        <div class="panel panel-success" style="box-shadow: 0 4px 8px rgba(0,0,0,0.1); border: none;">
            <div class="panel-heading" style="background-color: #2ecc71; color: white;">
                <div class="row">
                    <div class="col-xs-3">
                        <i class="glyphicon glyphicon-piggy-bank" style="font-size: 60px;"></i>
                    </div>
                    <div class="col-xs-9 text-right">
                        <div style="font-size: 36px; font-weight: bold;">@String.Format("{0:0,0}", ViewBag.TongDoanhThu) VNĐ</div>
                        <div style="font-size: 16px;">Tổng Doanh Thu</div>
                    </div>
                </div>
            </div>
            <a href="@Url.Action("Index", "DonHang", new { area = "Admin" })">
                <div class="panel-footer" style="color: #2ecc71; font-weight: bold;">
                    <span class="pull-left">Xem báo cáo doanh thu</span>
                    <span class="pull-right"><i class="glyphicon glyphicon-circle-arrow-right"></i></span>
                    <div class="clearfix"></div>
                </div>
            </a>
        </div>
    </div>
</div>

<hr style="border-top: 2px dashed #ecf0f1; margin: 30px 0;" />

<h3 style="margin-bottom: 25px; color: #2c3e50; font-weight: bold;">
    <i class="glyphicon glyphicon-flash"></i> LỐI TẮT QUẢN LÝ
</h3>
<div class="row">
    <div class="col-md-3 col-sm-6">
        <a href="@Url.Action("Index", "Sach", new { area = "Admin" })" class="btn btn-primary btn-lg btn-block" style="padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: all 0.3s;">
            <i class="glyphicon glyphicon-book" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Quản lý Sách
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="@Url.Action("Index", "KhachHang", new { area = "Admin" })" class="btn btn-info btn-lg btn-block" style="padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: all 0.3s;">
            <i class="glyphicon glyphicon-user" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Khách Hàng
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="@Url.Action("Index", "ChuDe", new { area = "Admin" })" class="btn btn-warning btn-lg btn-block" style="padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: all 0.3s;">
            <i class="glyphicon glyphicon-tags" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Chủ Đề
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="@Url.Action("Index", "NhaXuatBan", new { area = "Admin" })" class="btn btn-danger btn-lg btn-block" style="padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: all 0.3s;">
            <i class="glyphicon glyphicon-print" style="font-size: 30px; display: block; margin-bottom: 10px;"></i>
            Nhà Xuất Bản
        </a>
    </div>
</div>
