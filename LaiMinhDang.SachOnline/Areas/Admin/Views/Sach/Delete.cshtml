@model LaiMinhDang.SachOnline.Models.SACH

@{
    ViewBag.Title = "Xóa Sách";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 style="text-align:center; color: red;">XÓA SÁCH</h2>

@if (ViewBag.ThongBao != null)
{
    <div class="alert alert-danger" style="text-align:center;">
        @ViewBag.ThongBao
    </div>
}
else
{
    <h3 style="text-align:center;">Bạn có chắc chắn muốn xóa cuốn sách này không?</h3>
}

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Tên sách:</dt>
        <dd>@Html.DisplayFor(model => model.TenSach)</dd>

        <dt>Ảnh bìa:</dt>
        <dd>
            <img src="~/images/@Model.AnhBia" style="width: 200px;" />
        </dd>

        <dt>Ngày cập nhật:</dt>
        <dd>@Html.FormatValue(Model.NgayCapNhat, "{0:dd/MM/yyyy}")</dd>

        <dt>Giá bán:</dt>
        <dd>@Html.FormatValue(Model.GiaBan, "{0:#,##0} VNĐ")</dd>

        <dt>Chủ đề:</dt>
        <dd>@Html.DisplayFor(model => model.CHUDE.TenChuDe)</dd>
    </dl>

    @using (Html.BeginForm("Delete", "Sach", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="form-actions no-color" style="margin-left: 100px;">
            <input type="submit" value="Xác nhận Xóa" class="btn btn-danger" /> |
            <a href="@Url.Action("Index")" class="btn btn-default">Về danh sách</a>
        </div>
    }
</div>