@model LaiMinhDang.SachOnline.Models.SACH

@{
    ViewBag.Title = "Thêm sách mới";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 style="text-align:center;">THÊM SÁCH MỚI</h2>

@using (Html.BeginForm("Create", "Sach", FormMethod.Post, new { @enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="form-group">
            <label class="control-label col-md-2">Tên sách:</label>
            <div class="col-md-10">
                <input type="text" name="TenSach" value="@ViewBag.TenSach" class="form-control" required />
                @Html.ValidationMessageFor(model => model.TenSach, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">Mô tả:</label>
            <div class="col-md-10">
                <textarea name="MoTa" class="form-control" rows="5">@ViewBag.MoTa</textarea>
                @Html.ValidationMessageFor(model => model.MoTa, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">Ảnh bìa:</label>
            <div class="col-md-10">
                <input type="file" name="fFileUpload" required />
                @if (ViewBag.ThongBao != null)
                {
                    <span class="text-danger">@ViewBag.ThongBao</span>
                }
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">Số lượng bán:</label>
            <div class="col-md-10">
                <input type="number" name="SoLuongBan" value="@ViewBag.SoLuongBan" class="form-control" required />
                @Html.ValidationMessageFor(model => model.SoLuongBan, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">Giá bán:</label>
            <div class="col-md-10">
                <input type="number" name="GiaBan" value="@ViewBag.GiaBan" class="form-control" required />
                @Html.ValidationMessageFor(model => model.GiaBan, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">Chủ đề:</label>
            <div class="col-md-10">
                @Html.DropDownList("MaCD", null, htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.MaCD, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">Nhà xuất bản:</label>
            <div class="col-md-10">
                @Html.DropDownList("MaNXB", null, htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.MaNXB, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Thêm mới" class="btn btn-primary" />
                <a href="@Url.Action("Index")" class="btn btn-default">Về danh sách</a>
            </div>
        </div>
    </div>
}