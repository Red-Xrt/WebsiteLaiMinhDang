@model LaiMinhDang.SachOnline.Models.DONDATHANG

@{
    ViewBag.Title = "Chi tiết Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var chiTiet = ViewBag.ChiTiet as List<LaiMinhDang.SachOnline.Models.CHITIETDATHANG>;
}

<h2 style="text-align:center;">CHI TIẾT ĐƠN HÀNG #@Model.MaDonHang</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Khách hàng:</dt>
        <dd>@(Model.KHACHHANG != null ? Model.KHACHHANG.HoTen : "Không rõ")</dd>

        <dt>Ngày đặt:</dt>
        <dd>@Html.FormatValue(Model.NgayDat, "{0:dd/MM/yyyy}")</dd>

        <dt>Ngày giao:</dt>
        <dd>@Html.FormatValue(Model.NgayGiao, "{0:dd/MM/yyyy}")</dd>

        <dt>Thanh toán:</dt>
        <dd>@(Model.DaThanhToan == true ? "Đã thanh toán" : "Chưa thanh toán")</dd>

        <dt>Giao hàng:</dt>
        <dd>@(Model.TinhTrangGiaoHang == 1 ? "Đã giao hàng" : "Chưa giao hàng")</dd>
    </dl>
</div>

<h4>Danh sách sản phẩm trong đơn hàng</h4>
<table class="table table-bordered">
    <tr class="info">
        <th>Ảnh bìa</th>
        <th>Tên sách</th>
        <th>Số lượng</th>
        <th>Đơn giá</th>
        <th>Thành tiền</th>
    </tr>
    @if (chiTiet != null)
    {
        foreach (var c in chiTiet)
        {
            <tr>
                <td><img src="~/images/@c.SACH.AnhBia" style="width: 50px;" /></td>
                <td>@c.SACH.TenSach</td>
                <td>@c.SoLuong</td>
                <td>@Html.FormatValue(c.DonGia, "{0:#,##0} VNĐ")</td>
                <td>@Html.FormatValue(c.SoLuong * c.DonGia, "{0:#,##0} VNĐ")</td>
            </tr>
        }
    }
</table>

<p>
    <a href="@Url.Action("Edit", new { id = Model.MaDonHang })" class="btn btn-warning">Cập nhật đơn</a> |
    <a href="@Url.Action("Index")" class="btn btn-default">Về danh sách</a>
</p>