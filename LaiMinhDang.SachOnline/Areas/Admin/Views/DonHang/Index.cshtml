@using LaiMinhDang.SachOnline.Models
@using PagedList.Mvc;
@model PagedList.PagedList<LaiMinhDang.SachOnline.Models.DONDATHANG>

@{
    ViewBag.Title = "Quản lý Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 style="text-align:center; font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin-bottom: 30px;">
    QUẢN LÝ ĐƠN HÀNG
</h2>

<table class="table table-bordered table-hover">
    <tr class="info">
        <th>Mã Đơn</th>
        <th>Tên Khách Hàng</th>
        <th>Ngày Đặt</th>
        <th>Ngày Giao</th>
        <th>Đã Thanh Toán</th>
        <th>Tình Trạng Giao</th>
        <th>Hành Động</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.MaDonHang</td>
            <td>@(item.KHACHHANG != null ? item.KHACHHANG.HoTen : "")</td>
            <td>@Html.FormatValue(item.NgayDat, "{0:dd/MM/yyyy}")</td>
            <td>@Html.FormatValue(item.NgayGiao, "{0:dd/MM/yyyy}")</td>
            <td>
                @if (item.DaThanhToan == true)
                {
                    <span class="label label-success">Đã thanh toán</span>
                }
                else
                {
                    <span class="label label-warning">Chưa thanh toán</span>
                }
            </td>
            <td>
                @if (item.TinhTrangGiaoHang == 1)
                {
                    <span class="label label-success">Đã giao</span>
                }
                else
                {
                    <span class="label label-warning">Chưa giao</span>
                }
            </td>
            <td>
                <a href="@Url.Action("Edit", new { id = item.MaDonHang })" class="btn btn-warning btn-sm">Cập nhật</a>
                <a href="@Url.Action("Details", new { id = item.MaDonHang })" class="btn btn-info btn-sm">Chi tiết</a>
            </td>
        </tr>
    }
</table>

<div>
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }))
</div>